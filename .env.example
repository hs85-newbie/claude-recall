# claude-recall 환경 변수
# 이 파일을 복사해 ~/.env 또는 레포 루트 .env 로 채우세요(.env는 gitignore됨).

# ── 필수 ──
# session-archive 요약(summarize) 단계에 필요.
ANTHROPIC_API_KEY=sk-ant-...

# ── 선택: 크로스머신 회상 (vault git 동기화) ──
# 설정하면 bootstrap이 vault를 클론하고, 파이프라인이 push/pull로 타 머신과 동기화.
# 미설정 시 로컬 전용 모드(크로스머신 회상 비활성).
LLM_WIKI_REMOTE=                 # 예: git@github.com:you/your-vault.git

# ── 선택: 한글 humanize 스킬 ──
IM_NOT_AI_REMOTE=                # 예: git@github.com:you/im-not-ai.git

# ── 선택: 머신 라벨 (기본값: hostname) ──
SESSION_ARCHIVE_MACHINE=

# ── 참고: GitHub Actions (dispatch/nightly 워크플로 쓸 때) ──
# 환경변수 아님. 레포 Settings → Variables 에 설정:
#   CLAUDE_GLOBAL_REPO = <your-user>/claude-recall   (중앙 설정 레포)
# 그리고 Secrets 에:  GLOBAL_SETTINGS_TOKEN = <PAT>
